generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  DOCTOR
  TECHNICIAN
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum PaymentMethod {
  CASH
  ONLINE
}

enum ReportStatus {
  READY
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  role           Role
  email          String    @unique
  password       String
  isActive       Boolean   @default(true)
  patients       Patient[]
  doctorOrders   Order[]   @relation("DoctorOrders")
  notifications  Notification[]
  createdAt      DateTime  @default(now())
}

model Patient {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  age         Int
  gender      String
  createdById Int
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdBy   User     @relation(fields: [createdById], references: [id])
  orders      Order[]
  createdAt   DateTime @default(now())
}

model Test {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  price      Decimal     @db.Decimal(10, 2)
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?
  orderTests OrderTest[]
  createdAt  DateTime    @default(now())
}

model Order {
  id         Int         @id @default(autoincrement())
  patientId  Int
  doctorId   Int
  status     OrderStatus @default(PENDING)
  sampleStatus String    @default("PENDING")
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?
  patient    Patient     @relation(fields: [patientId], references: [id])
  doctor     User        @relation("DoctorOrders", fields: [doctorId], references: [id])
  orderTests OrderTest[]
  payments   Payment[]
  reports    Report[]
  createdAt  DateTime    @default(now())
}

model OrderTest {
  orderId   Int
  testId    Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test      Test    @relation(fields: [testId], references: [id])

  @@id([orderId, testId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  orderId   Int
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod
  isDeleted Boolean       @default(false)
  deletedAt DateTime?
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

model Report {
  id        Int      @id @default(autoincrement())
  orderId   Int
  fileName  String
  fileUrl   String
  filePath  String
  fileType  String
  status    String   @default("UPLOADED")
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId Int
  recipient   User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type        String
  title       String
  message     String
  entityType  String?
  entityId    Int?
  metadata    Json?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  actorRole  Role?
  entityType String
  entityId   Int?
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
}
